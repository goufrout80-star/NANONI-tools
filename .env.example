# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# hCaptcha (get free key at hcaptcha.com)
VITE_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key

